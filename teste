        "\$.opcoes_produtos_disponiveis[0].dados_produto[?(@.id=='idIntencao')].valor"
    ]
    
    Map<String, Object> validar(ExecutionMock execution) {
        errors.clear()
        
        println "\n🔍 VARIÁVEIS RECEBIDAS:"
        execution.variables.each { key, value ->
            println "   $key = ${value?.toString()?.take(100)}${value?.toString()?.length() > 100 ? '...' : ''}"
        }
        
        def ofertaCartao = execution.getVariable("oferta_cartao")
        def ofertaCartaoNpc = execution.getVariable("oferta_cartao_npc")
        
        def ofertaCartaoValida = !isNullOrEmpty(ofertaCartao)
        def ofertaCartaoNpcValida = !isNullOrEmpty(ofertaCartaoNpc)
        
        println "\n📊 ANÁLISE:"
        println "   oferta_cartao: ${ofertaCartaoValida ? 'PRESENTE' : 'AUSENTE'}"
        println "   oferta_cartao_npc: ${ofertaCartaoNpcValida ? 'PRESENTE' : 'AUSENTE'}"
        
        // Validação de oferta_cartao / oferta_cartao_npc (exclusividade)
        if ((!ofertaCartaoValida && !ofertaCartaoNpcValida) || (ofertaCartaoValida && ofertaCartaoNpcValida)) {
            def erro = "Exatamente uma das variáveis oferta_cartao ou oferta_cartao_npc deve ser fornecida."
            println "\n❌ ERRO DE EXCLUSIVIDADE: $erro"
            println "   Status: oferta_cartao=${ofertaCartaoValida}, oferta_cartao_npc=${ofertaCartaoNpcValida}"
            addError("oferta_cartao ou oferta_cartao_npc", erro)
        } else if (ofertaCartaoNpcValida) {
            println "\n✅ VALIDANDO oferta_cartao_npc..."
            validarOfertaCartaoNpc(ofertaCartaoNpc)
        } else if (ofertaCartaoValida) {
            println "\n✅ VALIDANDO oferta_cartao..."
            validarOfertaCartao(ofertaCartao)
        }
        
        // Validação de oferta_produtos
        println "\n📦 VALIDANDO oferta_produtos..."
        validarOfertaProdutos(execution.getVariable("oferta_produtos"))
        
        // Validação de oferta_pacote
        println "\n📦 VALIDANDO oferta_pacote..."
        validarOfertaPacote(execution.getVariable("oferta_pacote"))
        
        // Campos Obrigatórios Tarefa
        println "\n🔢 VALIDANDO motor_efetivacao_id_origem..."
        validarMotorEfetivacaoIdOrigem(execution.getVariable("motor_efetivacao_id_origem"))
        
        return [
            success: errors.isEmpty(),
            errors: errors,
            errorMessage: errors.isEmpty() ? null : JsonOutput.prettyPrint(JsonOutput.toJson(errors))
        ]
    }
    
    private void validarOfertaCartaoNpc(def ofertaCartaoNpc) {
        println "   Conteúdo oferta_cartao_npc: ${ofertaCartaoNpc?.toString()?.take(200)}..."
        
        ofertaCartaoNpcCaminhosObrigatorios.each { caminho ->
            try {
                def jsonObj = JSON(ofertaCartaoNpc)
                def pathMock = new JsonPathMock(jsonObj)
                def elements = pathMock.jsonPath(caminho).elementList()
                
                if (elements.isEmpty()) {
                    println "   ❌ Campo obrigatório não encontrado: $caminho"
                    addError(caminho, "Campo obrigatorio nao encontrado.")
                } else if (elements.size() > 1) {
                    println "   ❌ Múltiplos valores: $caminho"
                    addError(caminho, "Campo obrigatorio contem multiplos valores, mas apenas um e permitido.")
                } else {
                    def element = elements[0]
                    if (element == null || (element instanceof String && element.trim().isEmpty())) {
                        println "   ❌ Campo vazio: $caminho"
                        addError(caminho, "Campo obrigatorio esta vazio.")
                    } else {
                        println "   ✅ Campo OK: $caminho = $element"
                    }
                }
            } catch (Exception e) {
                println "   ❌ Erro ao validar $caminho: ${e.message}"
                addError(caminho, "Campo obrigatorio nao encontrado. Erro: ${e.message}")
            }
        }
    }
    
    private void validarOfertaCartao(def ofertaCartao) {
        println "   Conteúdo oferta_cartao: ${ofertaCartao?.toString()?.take(200)}..."
        
        camposObrigatoriosOfertaCartao.each { campo ->
            try {
                def jsonObj = JSON(ofertaCartao)
                def pathMock = new JsonPathMock(jsonObj)
                def elements = pathMock.jsonPath(campo).elementList()
                
                if (elements.isEmpty()) {
                    println "   ❌ Campo obrigatório não encontrado: $campo"
                    addError(campo, "Campo obrigatorio nao encontrado.")
                } else if (elements.size() > 1) {
                    println "   ❌ Múltiplos valores: $campo"
                    addError(campo, "Campo obrigatorio contem multiplos valores, mas apenas um e permitido.")
                } else {
                    def element = elements[0]
                    if (element == null || (element instanceof String && element.trim().isEmpty())) {
                        println "   ❌ Campo vazio: $campo"
                        addError(campo, "Campo obrigatorio esta vazio.")
                    } else {
                        println "   ✅ Campo OK: $campo = $element"
                    }
                }
            } catch (Exception e) {
                println "   ❌ Erro ao validar $campo: ${e.message}"
                addError(campo, "Campo obrigatorio nao encontrado. Erro: ${e.message}")
            }
        }
    }
    
    private void validarOfertaProdutos(def ofertaProdutos) {
        if (isNullOrEmpty(ofertaProdutos)) {
            println "   ❌ oferta_produtos está AUSENTE ou VAZIO"
            addError("oferta_produtos", "Campo obrigatório")
        } else if (ofertaProdutos instanceof Map) {
            println "   ✅ oferta_produtos presente: $ofertaProdutos"
            def aplicaut = ofertaProdutos["aplicaut"]
            if (aplicaut != null && aplicaut instanceof Map) {
                def indicadorContratar = aplicaut["indicador_contratar"]
                if (indicadorContratar == null) {
                    println "   ❌ indicador_contratar ausente"
                    addError("aplicaut.indicador_contratar", "Campo obrigatório")
                } else if (!(indicadorContratar instanceof Boolean)) {
                    println "   ❌ indicador_contratar não é boolean: $indicadorContratar"
                    addError("aplicaut.indicador_contratar", "Deve ser boolean")
                } else {
                    println "   ✅ indicador_contratar OK: $indicadorContratar"
                }
            } else {
                println "   ❌ Estrutura aplicaut não encontrada"
                addError("oferta_produtos.aplicaut", "Estrutura aplicaut não encontrada ou inválida")
            }
        } else {
            println "   ❌ oferta_produtos não é um Map: ${ofertaProdutos.getClass()}"
            addError("oferta_produtos", "Deve ser um objeto Map")
        }
    }
    
    private void validarOfertaPacote(def ofertaPacote) {
        if (isNullOrEmpty(ofertaPacote)) {
            println "   ❌ oferta_pacote está AUSENTE ou VAZIO"
            addError("oferta_pacote", "Campo obrigatório")
        } else if (ofertaPacote instanceof Map) {
            println "   ✅ oferta_pacote presente: $ofertaPacote"
            camposObrigatoriosOfertaPacote.each { campo ->
                if (!ofertaPacote.containsKey(campo) || ofertaPacote[campo] == null) {
                    println "   ❌ Campo obrigatório ausente: $campo"
                    addError("oferta_pacote.${campo}", "Campo obrigatório")
                } else if (ofertaPacote[campo] instanceof String && ofertaPacote[campo].trim().isEmpty()) {
                    println "   ❌ Campo vazio: $campo"
                    addError("oferta_pacote.${campo}", "Campo obrigatório não pode ser vazio")
                } else {
                    println "   ✅ Campo OK: $campo = ${ofertaPacote[campo]}"
                }
            }
        } else {
            println "   ❌ oferta_pacote não é um Map: ${ofertaPacote.getClass()}"
            addError("oferta_pacote", "Deve ser um objeto Map")
        }
    }
    
    private void validarMotorEfetivacaoIdOrigem(def valor) {
        if (isNullOrEmpty(valor)) {
            println "   ❌ motor_efetivacao_id_origem ausente ou vazio"
            addError("motor_efetivacao_id_origem", "Campo obrigatório")
        } else {
            println "   ✅ motor_efetivacao_id_origem OK: $valor"
        }
    }
    
