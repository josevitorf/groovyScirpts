import groovy.json.JsonSlurper
import groovy.json.JsonOutput

class ValidadorOferta {
    
    List<Map<String, String>> errors = []
    
    // Mock do execution
    static class ExecutionMock {
        def variables = [:]
        
        def getVariable(String name) {
            return variables[name]
        }
        
        void setVariable(String name, value) {
            variables[name] = value
        }
    }
    
    // Classe para simular o JSON path
    static class JsonPathMock {
        private Object json
        
        JsonPathMock(Object json) {
            this.json = json
        }
        
        def jsonPath(String path) {
            return new JsonPathResultMock(evaluatePath(path))
        }
        
        private Object evaluatePath(String path) {
            def current = json
            path = path.replace('$.', '')
            
            if (path.contains('[?(')) {
                return evaluateFilterPath(path, current)
            }
            
            path.split('\\.').each { part ->
                if (current == null) return null
                
                if (part.contains('[')) {
                    def arrayPart = part.substring(0, part.indexOf('['))
                    def index = part.substring(part.indexOf('[') + 1, part.indexOf(']')).toInteger()
                    
                    if (current[arrayPart] != null && current[arrayPart].size() > index) {
                        current = current[arrayPart][index]
                    } else {
                        current = null
                    }
                } else {
                    current = current[part]
                }
            }
            
            return current
        }
        
        private Object evaluateFilterPath(String path, Object json) {
            if (path.contains('?(@.id_oferta!=null)]')) {
                return json.opcoes_produtos_disponiveis?.findAll { it.id_oferta != null }
            }
            if (path.contains('?(@.id==\'ofertas\')')) {
                return json.dados_produto?.findAll { it.id == 'ofertas' }
            }
            if (path.contains('?(@.id!=null)')) {
                return json.valor?.findAll { it.id != null }
            }
            if (path.contains('?(@.idProduto!=null)')) {
                return json.produtos?.findAll { it.idProduto != null }
            }
            if (path.contains('?(@.idPlano!=null)')) {
                return json.planos?.findAll { it.idPlano != null }
            }
            return []
        }
    }
    
    static class JsonPathResultMock {
        private Object result
        
        JsonPathResultMock(Object result) {
            this.result = result
        }
        
        def elementList() {
            if (result instanceof List) return result
            if (result != null) return [result]
            return []
        }
        
        def element() {
            if (result instanceof List && result.size() == 1) return result[0]
            return result
        }
        
        def isNull() {
            return result == null
        }
        
        def isString() {
            return result instanceof String
        }
        
        def stringValue() {
            return result?.toString()
        }
    }
    
    static def JSON = { obj ->
        if (obj instanceof String) {
            return new JsonSlurper().parseText(obj)
        }
        return obj
    }
    
    def addError = { String field, String message ->
        errors.add(["campo": field, "mensagem": message])
    }
    
    def isNullOrEmpty = { obj ->
        obj == null ||
            (obj instanceof String && (obj == "null" || obj.trim().isEmpty())) ||
            (obj instanceof Map && obj.isEmpty()) ||
            (obj instanceof List && obj.isEmpty())
    }
    
    def camposObrigatoriosOfertaPacote = [
        "codigoPacote",
        "nomePacote",
        "valorPacote"
    ]
    
    def camposObrigatoriosOfertaCartao = [
        "\$.bandeira_cartao",
        "\$.codigo_fatura_digital_cartao",
        "\$.codigo_tipo_cartao",
        "\$.dia_vencimento_cartao",
        "\$.dn_cartao_credito",
        "\$.dn_cartao_debito",
        "\$.indicador_debito_automatico",
        "\$.indicador_oferta_fatura",
        "\$.indicador_opcao_seguro_cartao",
        "\$.indicador_overlimit",
        "\$.indicador_programa_recompensa",
        "\$.numero_de_parcela",
        "\$.tipo_cartao",
        "\$.valor_da_parcela",
        "\$.valor_maximo_cartao",
        "\$.valor_minimo_cartao",
        "\$.valor_total_anuidade_cartao"
    ]
    
    def ofertaCartaoNpcCaminhosObrigatorios = [
        "\$.data_vencimento",
        "\$.opcoes_produtos_disponiveis[?(@.id_oferta!=null)].id_oferta",
        "\$.opcoes_produtos_disponiveis[0].dados_produto[?(@.id=='ofertas')].id",
        "\$.opcoes_produtos_disponiveis[0].dados_produto[?(@.id=='ofertas')].valor[?(@.id!=null)].id",
        "\$.opcoes_produtos_disponiveis[0].dados_produto[?(@.id=='ofertas')].valor[0].produtos[?(@.idProduto!=null)].idProduto",
        "\$.opcoes_produtos_disponiveis[0].dados_produto[?(@.id=='ofertas')].valor[0].produtos[0].dadosProduto.planos[?(@.idPlano!=null)].idPlano",
        "\$.opcoes_produtos_disponiveis[0].dados_produto[?(@.id=='ofertas')].valor[0].produtos[0].dadosProduto.dn",
        "\$.opcoes_produtos_disponiveis[0].dados_produto[?(@.id=='canal')].valor.canalOrigem",
